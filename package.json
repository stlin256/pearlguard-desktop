{
  "name": "pearlguard-desktop",
  "version": "0.3.0",
  "description": "A lightweight cross-platform desktop companion for local Pearl Wallet monitoring, address history, balance curves, and mining pool intelligence.",
  "main": "main.go",
  "author": {
    "name": "PearlGuard Maintainers",
    "email": "maintainers@example.invalid"
  },
  "license": "MIT",
  "homepage": "https://github.com/stlin256/pearlguard-desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stlin256/pearlguard-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/stlin256/pearlguard-desktop/issues"
  },
  "scripts": {
    "start": "wails dev",
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/unit-tests.mjs",
    "test:e2e": "node scripts/wails-smoke.mjs",
    "privacy:scan": "node scripts/privacy-scan.mjs",
    "build:wails-assets": "node scripts/prepare-wails-assets.mjs",
    "dist": "wails build -clean -trimpath -ldflags \"-s -w\" -webview2 browser -o PearlGuard-Desktop.exe",
    "generate:icon": "node scripts/generate-icon.mjs"
  },
  "devDependencies": {}
}
